# ─── Database ────────────────────────────────────────────────────────────────
# Get this from Neon (neon.tech) after creating a free project
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ─── Admin Auth ───────────────────────────────────────────────────────────────
# Password your wife uses to log into /admin
ADMIN_PASSWORD=choose-a-strong-password

# Secret used to sign JWT tokens — generate with: openssl rand -base64 32
JWT_SECRET=replace-with-a-random-secret-string

# ─── Cloudflare R2 (image storage) ───────────────────────────────────────────
# Found in Cloudflare dashboard → R2
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=your-bucket-name
# The public URL for your R2 bucket (enable in R2 → bucket → Settings → Public access)
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxxxxxx.r2.dev

# ─── CORS (only needed for local dev if frontend/backend run on different ports) ─
# ALLOWED_ORIGINS=http://localhost:5173
