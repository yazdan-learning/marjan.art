{
  "version": 2,
  "buildCommand": "pnpm install --no-frozen-lockfile && pnpm --filter @workspace/artist-portfolio run build",
  "outputDirectory": "artifacts/artist-portfolio/dist/public",
  "functions": {
    "api/index.ts": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index" }
  ]
}
